# HTTP server port (API_PORT is accepted as an alias)
PORT=3001

# SQLite database file path (relative to backend/ when running locally)
DATABASE_PATH=./data/promotions.db

# Delay between sequential scrape HTTP requests (milliseconds)
SCRAPE_DELAY_MS=500

# Per-request HTTP timeout (milliseconds)
REQUEST_TIMEOUT_MS=15000

# Allowed origin for Socket.IO CORS (Next.js dev server by default)
FRONTEND_URL=http://localhost:3000

# Morgan log format: "dev" when unset/non-production, "combined" in production
NODE_ENV=development
